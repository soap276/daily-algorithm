# 아래 코드를 조금 더 많이 활용하게 될 것
name = ['Min', 'CO', 'TIM']

def recur2(idx, subset):
    if idx == 3:
        print(*subset)
        return
    # 포함 하는 경우
    recur2(idx+1, subset + [name[idx]])
    # 안 하는 경우
    recur2(idx+1, subset)


recur2(0, [])


# 바이너리 카운트
arr = ['A', 'B', 'C', 'D', 'E']
n = len(arr)

def get_count(tar):
    cnt = 0
    for _ in range(n):
        if tar & 0x1:
            cnt += 1
        tar >>= 1

    return cnt

answer = 0
for target in range(1<<n):
    if get_count(target) >= 2:
        answer += 1

print(answer)

# 조합문제
# 5명 중 n명을 뽑을 것이다, 순서 상관 없음
arr = ['A', 'B', 'C', 'D', 'E']
N = 3
path = []

# n명 을 뽑는다 -> depth : n
# 5명 중 하나를 선택 -> branch : 5
# 1. 전체 순열 코드부터 시작
# 2. 직전 선택을 다음 재귀호출로 넘겨주고, 그 다음부터 선택하도록 구성

def recur(cnt, prev):
    if cnt == N:
        print(*path)
        return

    # 중복 제거된 조합: 이전에 선택했던 것 다음거부터 탐색하자!
    # 중복 조합: 이전에 선택했던 것부터 탐색 (중복을 허용)
    for i in range(prev, len(arr)):
        path.append(arr[i])
        recur(cnt+1, i) # 이전 선택을 함께 전달
        path.pop()

# recur(0, -1) # 중복 제거
recur(0, 0) # 중복 허용












