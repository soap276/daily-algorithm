# 부분집합 찾는 구현 방법
# 1. 완전탐색 - 재귀호출을 이용한 완탐
# 2. binary counting - 모든 부분 집합이 필요할 때 사용

# 3명의 친구 부분집합 만들기
arr = ["O", "X"]
path = []
# 3명의 친구: depth 3
# O, X 중 하나 선택: branch는 2개
def recur(cnt):
    if cnt == 3:
        print(path)
        return

    # O을 선택 (부분집합에 포함 되는 경우)
    path.append(arr[0])
    recur(cnt + 1)
    path.pop()

    # X를 선택
    path.append(arr[1])
    recur(cnt + 1)
    path.pop()


recur(0)

